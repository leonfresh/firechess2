# Database (Neon Postgres)
DATABASE_URL=

# Auth.js
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_LICHESS_ID=
AUTH_RESEND_KEY=
AUTH_RESEND_FROM=FireChess <noreply@firechess.com>

# App URL (used for callbacks + social sharing)
NEXT_PUBLIC_APP_URL=https://firechess.com

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_LIFETIME=
STRIPE_WEBHOOK_SECRET=

# Local/dev only: set to false to disable tilde (~) hotkey for Local Pro mode
NEXT_PUBLIC_ENABLE_LOCAL_PRO_HOTKEY=true

# Lichess API token (required for Opening Explorer - get one at https://lichess.org/account/oauth/token, no scopes needed)
LICHESS_API_TOKEN=

# PartyKit (real-time WebSocket for Chaos Chess multiplayer)
# Local dev: localhost:1999 (run `npm run party:dev`)
# Production: your-project.username.partykit.dev (after `npm run party:deploy`)
NEXT_PUBLIC_PARTYKIT_HOST=localhost:1999
